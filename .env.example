# Database
DATABASE_URL=postgresql+asyncpg://ipl:ipl_secret@localhost:5432/ipl_fantasy
DATABASE_URL_SYNC=postgresql://ipl:ipl_secret@localhost:5432/ipl_fantasy

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:5173

# Cricbattle Scraper
CRICBATTLE_EMAIL=your-cricbattle-email
CRICBATTLE_PASSWORD=your-cricbattle-password
CRICBATTLE_LEAGUE_ID=676423

# Auto-scrape scheduler
SCRAPE_HOURS_IST=1,13
SCRAPE_SEASON_ID=
